APP_NAME=visual-companion
DATABASE_URL=sqlite:///./petbot.db
UPLOAD_DIR=./uploads
ASSET_DIR=./assets

# 内置 AI 模型配置
BUILTIN_PROVIDER_KEY=
BUILTIN_MODEL=gpt-image-2
BUILTIN_API_BASE=https://www.micuapi.ai/v1

# JWT 认证
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 配额
MAX_FREE_GENERATIONS=5

CORS_ORIGINS=*

# AI sprite sheet generation
SPRITE_GENERATION_ENABLED=true
SPRITE_MAX_REGENERATE_ATTEMPTS=2
